{
  "name": "@codemonster-ru/vueforge-core",
  "version": "1.17.1",
  "description": "Foundation layer for the VueForge design system.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/codemonster-ru/vueforge-core#readme",
  "bugs": {
    "url": "https://github.com/codemonster-ru/vueforge-core/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/codemonster-ru/vueforge-core.git"
  },
  "keywords": [
    "vue",
    "vue3",
    "typescript",
    "ui",
    "components",
    "design-system",
    "theme",
    "library",
    "vueforge"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "module": "./dist/vueforge-core.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "foundation": [
        "dist/foundation/index.d.ts"
      ],
      "theme": [
        "dist/theme/public.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vueforge-core.js"
    },
    "./styles.css": "./dist/styles.css",
    "./tokens.css": "./dist/tokens.css",
    "./foundation.css": "./dist/foundation.css",
    "./foundation": {
      "types": "./dist/foundation/index.d.ts",
      "import": "./dist/foundation-api.js"
    },
    "./theme": {
      "types": "./dist/theme/public.d.ts",
      "import": "./dist/theme-api.js"
    }
  },
  "scripts": {
    "build": "vue-tsc --noEmit && vite build",
    "check": "npm run lint && npm run test && npm run build",
    "dev": "vite --force",
    "format": "prettier --write .",
    "lint": "eslint .",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/jsdom": "^21.1.7",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.2.2",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^3.0.9",
    "vue": "^3.5.13",
    "vue-eslint-parser": "^10.1.1",
    "vue-tsc": "^2.2.8"
  },
  "dependencies": {
    "@codemonster-ru/floater.js": "^1.0.8",
    "@codemonster-ru/vueforge-theme": "^1.2.2",
    "@codemonster-ru/vueiconify": "^1.2.0"
  },
  "overrides": {
    "@microsoft/api-extractor": "^7.58.1"
  }
}
